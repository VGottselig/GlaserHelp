        padding: 0.0625in;
        min-height: 0.5in;
        color: #fff;
        background: #d5dbe1; 
	opacity: 0.95;
	box-shadow: 1px 1px 3px #888888;
      } 
      #headernav {  
	width: 0.833in;
        height: 0.2708in;
        margin: 0px 38px 0px 0px;
        padding: 0;
        float: right; 
      } 
      #content { 
        margin-top: 3.125em;
        padding: 0.375em;
      }
     img.nav { width: 0.2708in; height: 0.2708in; border: none; }
     #callout-table, #overview-table {display:block; position:relative; top:0; left:0;}

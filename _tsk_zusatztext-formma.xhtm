     #overview-table a {text-decoration: none; color: black;}
     #overview-table a:visited {text-decoration: none; color: black;}
     #callout-table a:hover, #overview-table a:hover {text-decoration: underline;} 
      p.crumbs { font-size: 9pt; margin: 0 0 0.0625in 0; color: #35383b }      
      p.crumbs a { text-decoration: underline; color: #35383b }
      p.crumbs a:hover{ color: #fff }      
      #switchtoggles { width:100%; text-align: right; padding: 0 0.0208in 0 0; font-size: 10pt; } 
      .sync-toc { color: #ffffff; font-size: 9pt; font-weight: bold; display: none; }
      .sync-toc a { color: #ffffff; text-decoration: none; font-weight: bold;}
      .sync-toc a:visited { color: #fff; }
      .sync-toc a:hover { text-decoration: underline; }
      a.hmanchor { display: inline-block; margin-top: 4em; padding-top: 4em }
      ._Hinweis {margin-top: 30px; margin-bottom: 30px }
      .Optionen-Palette {margin-top: 10px}

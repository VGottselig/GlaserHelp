<div id="content">
     <!--ZOOMRESTART-->
     <h5 class="p_Heading5"><span class="f_Heading5">Allgemeine Neuerungen</span></h5>
<p class="p_L_Listeneintrag" style="text-indent: 0; padding-left: 0.1354in; margin-left: 0.3958in;"><span style="display:inline-block;width:0.1354in;margin-left:-0.1354in;font-size:11pt;font-family:'Symbol';font-style:normal;color:#000000;text-decoration:none;">&#183;</span><span class="f_L_Listeneintrag">Automatische Aktualisierung der -isb cad- Installation mit regelm&auml;&szlig;iger &Uuml;berpr&uuml;fung</span></p>
<p class="p_L_Listeneintrag" style="text-indent: 0; padding-left: 0.1354in; margin-left: 0.3958in;"><span style="display:inline-block;width:0.1354in;margin-left:-0.1354in;font-size:11pt;font-family:'Symbol';font-style:normal;color:#000000;text-decoration:none;">&#183;</span><span class="f_L_Listeneintrag">Schnelle Navigation auf dem Plan durch neue Pan-Funktion</span></p>
<p class="p_L_Listeneintrag" style="text-indent: 0; padding-left: 0.1354in; margin-left: 0.3958in;"><span style="display:inline-block;width:0.1354in;margin-left:-0.1354in;font-size:11pt;font-family:'Symbol';font-style:normal;color:#000000;text-decoration:none;">&#183;</span><span class="f_L_Listeneintrag">Druck-, Plot- und PDF-Vorschau: Echtdarstellung der Strichst&auml;rke</span></p>
<p class="p_L_Listeneintrag" style="text-indent: 0; padding-left: 0.1354in; margin-left: 0.3958in;"><span style="display:inline-block;width:0.1354in;margin-left:-0.1354in;font-size:11pt;font-family:'Symbol';font-style:normal;color:#000000;text-decoration:none;">&#183;</span><span class="f_L_Listeneintrag">Neue einheitliche Dialoge f&uuml;r Datei lesen und Datei schreiben in allen Unterprogrammen</span></p>
<p class="p_L_Listeneintrag" style="text-indent: 0; padding-left: 0.1354in; margin-left: 0.3958in;"><span style="display:inline-block;width:0.1354in;margin-left:-0.1354in;font-size:11pt;font-family:'Symbol';font-style:normal;color:#000000;text-decoration:none;">&#183;</span><span class="f_L_Listeneintrag">Sowie-Schalter f&uuml;r Ma&szlig;ketten </span></p>
<p class="p_L_Listeneintrag" style="text-indent: 0; padding-left: 0.1354in; margin-left: 0.3958in;"><span style="display:inline-block;width:0.1354in;margin-left:-0.1354in;font-size:11pt;font-family:'Symbol';font-style:normal;color:#000000;text-decoration:none;">&#183;</span><span class="f_L_Listeneintrag">Vorschau f&uuml;r weitere Kreisfunktionen</span></p>
<p class="p_L_Listeneintrag" style="text-indent: 0; padding-left: 0.1354in; margin-left: 0.3958in;"><span style="display:inline-block;width:0.1354in;margin-left:-0.1354in;font-size:11pt;font-family:'Symbol';font-style:normal;color:#000000;text-decoration:none;">&#183;</span><span class="f_L_Listeneintrag">Verbesserte Definitionsdialoge in allen Teilprogrammen</span></p>
<p class="p_L_Listeneintrag" style="text-indent: 0; padding-left: 0.1354in; margin-left: 0.3958in;"><span style="display:inline-block;width:0.1354in;margin-left:-0.1354in;font-size:11pt;font-family:'Symbol';font-style:normal;color:#000000;text-decoration:none;">&#183;</span><span class="f_L_Listeneintrag">Effizientere Verwaltung von Folien und Foliengruppen</span></p>
<p class="p_L_Listeneintrag" style="text-indent: 0; padding-left: 0.1354in; margin-left: 0.3958in;"><span style="display:inline-block;width:0.1354in;margin-left:-0.1354in;font-size:11pt;font-family:'Symbol';font-style:normal;color:#000000;text-decoration:none;">&#183;</span><span class="f_L_Listeneintrag">Koordinatenverma&szlig;ung mit freier Zuordnung der Datenreihen</span></p>
<p class="p_L_Listeneintrag" style="text-indent: 0; padding-left: 0.1354in; margin-left: 0.3958in;"><span style="display:inline-block;width:0.1354in;margin-left:-0.1354in;font-size:11pt;font-family:'Symbol';font-style:normal;color:#000000;text-decoration:none;">&#183;</span><span class="f_L_Listeneintrag">Ausgabe von Dateistapeln noch leistungsf&auml;higer</span></p>
<p class="p_L_Listeneintrag" style="text-indent: 0; padding-left: 0.1354in; margin-left: 0.3958in;"><span style="display:inline-block;width:0.1354in;margin-left:-0.1354in;font-size:11pt;font-family:'Symbol';font-style:normal;color:#000000;text-decoration:none;">&#183;</span><span class="f_L_Listeneintrag">PDF2AKT: Weitere Optionen f&uuml;r PDF-Import </span></p>
<p class="p_L_Listeneintrag" style="text-indent: 0; padding-left: 0.1354in; margin-left: 0.3958in;"><span style="display:inline-block;width:0.1354in;margin-left:-0.1354in;font-size:11pt;font-family:'Symbol';font-style:normal;color:#000000;text-decoration:none;">&#183;</span><span class="f_L_Listeneintrag">Holzbau: Verbindungsbilder nach Eurocode 5 </span></p>
<p class="p_L_Listeneintrag" style="text-indent: 0; padding-left: 0.1354in; margin-left: 0.3958in;"><span style="display:inline-block;width:0.1354in;margin-left:-0.1354in;font-size:11pt;font-family:'Symbol';font-style:normal;color:#000000;text-decoration:none;">&#183;</span><span class="f_L_Listeneintrag">Mattenbewehrung:</span></p>
<p class="p_L_Listenunterpunkt" style="text-indent: 0; padding-left: 0.1354in; margin-left: 0.6354in;"><span class="f_L_Listenunterpunkt" style="font-family: 'Arial';display:inline-block;width:0.1354in;margin-left:-0.1354in">&#8211;</span><span class="f_L_Listenunterpunkt">Verlegung an ge&auml;nderte Geometrie anpassen</span></p>
<p class="p_L_Listenunterpunkt" style="text-indent: 0; padding-left: 0.1354in; margin-left: 0.6354in;"><span class="f_L_Listenunterpunkt" style="font-family: 'Arial';display:inline-block;width:0.1354in;margin-left:-0.1354in">&#8211;</span><span class="f_L_Listenunterpunkt">Durchbr&uuml;che einf&uuml;gen</span></p>
<p class="p_L_Listenunterpunkt" style="text-indent: 0; padding-left: 0.1354in; margin-left: 0.6354in;"><span class="f_L_Listenunterpunkt" style="font-family: 'Arial';display:inline-block;width:0.1354in;margin-left:-0.1354in">&#8211;</span><span class="f_L_Listenunterpunkt">Resteverwaltung mit wahlweise gro&szlig;en oder kleinen Restst&uuml;cken und Markierung im Plan</span></p>
<p class="p_L_Listenunterpunkt" style="text-indent: 0; padding-left: 0.1354in; margin-left: 0.6354in;"><span class="f_L_Listenunterpunkt" style="font-family: 'Arial';display:inline-block;width:0.1354in;margin-left:-0.1354in">&#8211;</span><span class="f_L_Listenunterpunkt">Statusleiste: Stahlmassen inkl. Listenmatten </span></p>
<p class="p_L_Listeneintrag" style="text-indent: 0; padding-left: 0.1354in; margin-left: 0.3958in;"><span style="display:inline-block;width:0.1354in;margin-left:-0.1354in;font-size:11pt;font-family:'Symbol';font-style:normal;color:#000000;text-decoration:none;">&#183;</span><span class="f_L_Listeneintrag">Bewehrungsdetails mit Formmatten </span></p>
<p class="p_L_Listeneintrag" style="text-indent: 0; padding-left: 0.1354in; margin-left: 0.3958in;"><span style="display:inline-block;width:0.1354in;margin-left:-0.1354in;font-size:11pt;font-family:'Symbol';font-style:normal;color:#000000;text-decoration:none;">&#183;</span><span class="f_L_Listeneintrag">Biegelistentext f&uuml;r Formmatten </span></p>
<p class="p_L_Listeneintrag" style="text-indent: 0; padding-left: 0.1354in; margin-left: 0.3958in;"><span style="display:inline-block;width:0.1354in;margin-left:-0.1354in;font-size:11pt;font-family:'Symbol';font-style:normal;color:#000000;text-decoration:none;">&#183;</span><span class="f_L_Listeneintrag">Durchstanzbewehrung Sch&ouml;ck Bole&reg; nach EC 2 und frei definierbare D&uuml;belleisten von Halfen &nbsp;</span></p>
<p class="p_L_Listeneintrag" style="text-indent: 0; padding-left: 0.1354in; margin-left: 0.3958in;"><span style="display:inline-block;width:0.1354in;margin-left:-0.1354in;font-size:11pt;font-family:'Symbol';font-style:normal;color:#000000;text-decoration:none;">&#183;</span><span class="f_L_Listeneintrag">Neues Infofenster f&uuml;r Formstahl- und Mattenverlegungen:</span></p>
<p class="p_L_Listenunterpunkt" style="text-indent: 0; padding-left: 0.1354in; margin-left: 0.6354in;"><span class="f_L_Listenunterpunkt" style="font-family: 'Arial';display:inline-block;width:0.1354in;margin-left:-0.1354in">&#8211;</span><span class="f_L_Listenunterpunkt">Voller Zugriff auf die Zoom- und Pan-Funktion</span></p>
<p class="p_L_Listenunterpunkt" style="text-indent: 0; padding-left: 0.1354in; margin-left: 0.6354in;"><span class="f_L_Listenunterpunkt" style="font-family: 'Arial';display:inline-block;width:0.1354in;margin-left:-0.1354in">&#8211;</span><span class="f_L_Listenunterpunkt">Auswahl &uuml;ber Auszug oder Verlegung m&ouml;glich</span></p>
<p class="p_L_Listenunterpunkt" style="text-indent: 0; padding-left: 0.1354in; margin-left: 0.6354in;"><span class="f_L_Listenunterpunkt" style="font-family: 'Arial';display:inline-block;width:0.1354in;margin-left:-0.1354in">&#8211;</span><span class="f_L_Listenunterpunkt">Hervorheben von Fehlern und Inkonsistenzen</span></p>
<p class="p_L_Listeneintrag" style="text-indent: 0; padding-left: 0.1354in; margin-left: 0.3958in;"><span style="display:inline-block;width:0.1354in;margin-left:-0.1354in;font-size:11pt;font-family:'Symbol';font-style:normal;color:#000000;text-decoration:none;">&#183;</span><span class="f_L_Listeneintrag"> Verlegung laufender Meter gem&auml;&szlig;. EC&nbsp;2 mit neuem Berechnungsdialog und &Auml;nderungsfunktion</span></p>
<p class="p_L_Listeneintrag" style="text-indent: 0; padding-left: 0.1354in; margin-left: 0.3958in;"><span style="display:inline-block;width:0.1354in;margin-left:-0.1354in;font-size:11pt;font-family:'Symbol';font-style:normal;color:#000000;text-decoration:none;">&#183;</span><span class="f_L_Listeneintrag"> Zusatzausz&uuml;ge orthog. zur Verlegung absetzen</span></p>
<p class="p_L_Listeneintrag" style="text-indent: 0; padding-left: 0.1354in; margin-left: 0.3958in;"><span style="display:inline-block;width:0.1354in;margin-left:-0.1354in;font-size:11pt;font-family:'Symbol';font-style:normal;color:#000000;text-decoration:none;">&#183;</span><span class="f_L_Listeneintrag"> Umstellung von DSTV-Schnittstelle und Trassierungsprogramm auf .NET</span></p>
     <!--ZOOMSTOP-->
